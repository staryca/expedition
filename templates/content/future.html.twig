{% extends 'base.content.html.twig' %}

{% block title %}
    Чакайце новыя відэа
{% endblock %}

{% block body %}
    <div class="container py-5">
        <h1 class="h2">Відэа</h1>
        <div class="row">
            <table class="table table-hover">
                <tbody>
                {% for key, marker in markers %}
                    <tr>
                        <td>
                            {{ titles.(key) }}
                            <button title="Расшыфроўка" class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="collapse" data-bs-target="#collapse{{ marker.id }}" aria-expanded="false" aria-controls="collapse{{ marker.id }}">
                                <i class="bi bi-arrow-down-square-fill"></i>
                            </button>
                            <div class="collapse" id="collapse{{ marker.id }}">
                                <div class="card card-body">
                                    {{ descriptions.(key)|raw }}
                                </div>
                            </div>
                        </td>
                        <td>
                            раніцай&nbsp;{{ marker.publish|date("d.m.Y", "Europe/Minsk") }}
                        </td>
                    </tr>
                {% endfor %}

                {% if not isAll %}
                    <tr><td colspan="2">...</td></tr>
                {% endif %}

                </tbody>
            </table>

        </div>
    </div>
{% endblock %}